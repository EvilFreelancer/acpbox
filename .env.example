# Gateway config via environment. Copy to .env and set values.
# All options can be set here; they override config.yaml.

# Path to YAML config (optional). If unset, only env and defaults are used.
CONFIG_PATH=config.yaml

# ACP server
# Command as JSON array, e.g. ["python","-m","uvicorn","acp_sdk.server.app:create_app","--host","127.0.0.1","--port","8000"]
ACP_COMMAND=["python", "-m", "uvicorn", "acp_sdk.server.app:create_app", "--host", "127.0.0.1", "--port", "8000"]
# Extra env for ACP process as JSON object, e.g. {}
ACP_ENV={}
ACP_STARTUP_TIMEOUT_SECONDS=30

# Gateway HTTP server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
# Base URL where ACP server listens (for /ping and API calls)
GATEWAY_ACP_BASE_URL=http://127.0.0.1:8000
